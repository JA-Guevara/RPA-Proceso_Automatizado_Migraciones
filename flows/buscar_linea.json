{
  "meta": {"name": "buscar_linea","retries": 1},

  "flow": [
    { "action": "wait", "wait_time": 3},

    { "action": "buscar_y_seleccionar", "target": {"referencia": "buscar_linea.busqueda_button", "imagenes": ["buscar_linea.inicial_busqueda"],"key_contexto": "existe_busqueda","transitorio": true},"clicks": 1,"max_intentos": 1},

    { "action": "click_y_escribir", "target": "buscar_linea.nro_linea_field", "value": "$nro_linea", "offset_x": 80,"clicks": 1},
    { "action": "click", "target": "buscar_linea.procesar_button","clicks": 1},
    
    { "action": "buscar_y_seleccionar", "target": {"referencia": "buscar_linea.confirmar_qvantel", "imagenes": ["buscar_linea.error_qvantel"],"key_contexto": "existe_error_qvantel","transitorio": true},"clicks": 1,"max_intentos": 1},

    { "action": "wait", "wait_time": 1}
  ],

  "salir_buscar_linea": [
    { "action": "wait", "wait_time": 1},
    { "action": "click", "target": "buscar_linea.salir_BCCS_button","clicks": 1,"transitorio": true},
    { "action": "wait", "wait_time": 1}
  ]
}