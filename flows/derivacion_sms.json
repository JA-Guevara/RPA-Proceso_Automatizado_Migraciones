{
  "meta": {"name": "derivacion_sms","retries": 1},

  "login": [
    { "action": "goto", "value": "$sms_url" },
    { "action": "fill", "target": "login.username_input", "value": "$sms_user" },
    { "action": "fill", "target": "login.password_input", "value": "$sms_password" },
    { "action": "click", "target": "login.login_button" }
  ],

  "derivacion": [
    { "action": "seleccionar_opcion_dropdown", "target": "derivacion.derivaciones_menu", "value": "Derivar Consulta" },
    { "action": "fill", "target": "derivacion.nro_cuenta_field", "value": "$nro_linea" },
    { "action": "seleccionar_opcion_dropdown", "target": "derivacion.tipo_plantilla_menu", "value": "Bajas Móvil Post Pago" },
    { "action": "click", "target": "derivacion.baja_post_pago_option" },
    { "action": "click", "target": "derivacion.button_agregar" },
    { "action": "click", "target": "derivacion.button_enviar" }

  ],

  "logout": [
    { "action": "click", "target": "logout.button_logout" }
  ]
}