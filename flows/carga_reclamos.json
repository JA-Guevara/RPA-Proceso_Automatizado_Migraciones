    { "action": "click_y_escribir", "target": "carga_reclamos.cargar_memo_field", "value": "$mensaje_memo","clicks": 1 },
    { "action": "click", "target": "carga_reclamos.aceptar_button","clicks": 1},
    { "action": "click", "target": "carga_reclamos.crear_button","clicks": 1}
  ],

  "reboot_carga_reclamos": [
    { "action": "press_key", "target": "esc", "repeticiones": 5 }
